# ============================================
# Medicinal Plants Platform - Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# General
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-secret-key

# API Gateway
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Auth Service
AUTH_SERVICE_HOST=0.0.0.0
AUTH_SERVICE_PORT=8001
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Plant Service
PLANT_SERVICE_HOST=0.0.0.0
PLANT_SERVICE_PORT=8002

# Chatbot Service
CHATBOT_SERVICE_HOST=0.0.0.0
CHATBOT_SERVICE_PORT=8003
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Search Service
SEARCH_SERVICE_HOST=0.0.0.0
SEARCH_SERVICE_PORT=8004

# User Service
USER_SERVICE_HOST=0.0.0.0
USER_SERVICE_PORT=8005

# PostgreSQL - Core Database
POSTGRES_CORE_HOST=postgres-core
POSTGRES_CORE_PORT=5432
POSTGRES_CORE_DB=medicinal_plants_core
POSTGRES_CORE_USER=mp_core_user
POSTGRES_CORE_PASSWORD=change-me-core-password

# PostgreSQL - Auth Database
POSTGRES_AUTH_HOST=postgres-auth
POSTGRES_AUTH_PORT=5434
POSTGRES_AUTH_DB=medicinal_plants_auth
POSTGRES_AUTH_USER=mp_auth_user
POSTGRES_AUTH_PASSWORD=change-me-auth-password

# PostgreSQL - Chatbot Database
POSTGRES_CHATBOT_HOST=postgres-chatbot
POSTGRES_CHATBOT_PORT=5436
POSTGRES_CHATBOT_DB=medicinal_plants_chatbot
POSTGRES_CHATBOT_USER=mp_chatbot_user
POSTGRES_CHATBOT_PASSWORD=change-me-chatbot-password

# PostgreSQL - User Database
POSTGRES_USER_HOST=postgres-user
POSTGRES_USER_PORT=5435
POSTGRES_USER_DB=medicinal_plants_user
POSTGRES_USER_USER=mp_user_user
POSTGRES_USER_PASSWORD=change-me-user-password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password

# Elasticsearch
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# PubMed / PubChem (External APIs)
PUBMED_API_KEY=your-pubmed-api-key
PUBMED_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils/
PUBCHEM_BASE_URL=https://pubchem.ncbi.nlm.nih.gov/rest/pug/

# PMC / NCBI APIs
PMC_IDCONV_BASE_URL=https://pmc.ncbi.nlm.nih.gov/tools/idconv/api/v1/articles/
PMC_OA_BASE_URL=https://www.ncbi.nlm.nih.gov/pmc/utils/oa/oa.fcgi
PMC_CITATION_BASE_URL=https://api.ncbi.nlm.nih.gov/lit/ctxp/v1/pubmed/
PMC_BIOC_BASE_URL=https://www.ncbi.nlm.nih.gov/research/bionlp/RESTful/pmcoa.cgi
NCBI_TOOL_NAME=QuimicaDeAltura
NCBI_TOOL_EMAIL=your-email@example.com

# Monitoring
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10
